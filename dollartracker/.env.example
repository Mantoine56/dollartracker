# Supabase Configuration
# Local Development Values
SUPABASE_URL=http://example.com:54321
SUPABASE_ANON_KEY=example_anon_key
SUPABASE_SERVICE_ROLE_KEY=example_service_role_key

# Database Connection
DATABASE_URL=postgresql://example_user:example_password@127.0.0.1:54322/example_db

# API Endpoints
EXPO_PUBLIC_API_URL=http://example.com:54321
EXPO_PUBLIC_GRAPHQL_URL=http://example.com:54321/graphql/v1
EXPO_PUBLIC_STORAGE_URL=http://example.com:54321/storage/v1/s3

# Authentication (Add these values when setting up auth providers)
GOOGLE_CLIENT_ID=example_google_client_id
GOOGLE_CLIENT_SECRET=example_google_client_secret
APPLE_SERVICE_ID=example_apple_service_id
APPLE_TEAM_ID=example_apple_team_id
APPLE_KEY_ID=example_apple_key_id

# App Configuration
EXPO_PUBLIC_APP_VARIANT=development

# Feature Flags
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Debugging
EXPO_PUBLIC_DEBUG_MODE=true

# Local Development Tools
STUDIO_URL=http://example.com:54323
INBUCKET_URL=http://example.com:54324
